
# =============================================

# Server
PORT=5000

MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/wavechat?retryWrites=true&w=majority&appName=YourAppName

# JWT Secret — use a long random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_replace_this

# Environment
NODE_ENV=development

# Frontend URL(s) for CORS — comma-separated for multiple origins
# e.g. production: CLIENT_URL=http://localhost:5173,https://wavechat-bay.vercel.app
CLIENT_URL=http://localhost:5173
